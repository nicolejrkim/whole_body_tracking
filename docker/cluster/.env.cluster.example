###
# Cluster specific settings
###

# Job scheduler used by cluster.
# Currently supports PBS and SLURM
CLUSTER_JOB_SCHEDULER=SLURM
# Docker cache dir for Isaac Sim (has to end on docker-isaac-sim)
# e.g. /cluster/scratch/$USER/docker-isaac-sim
CLUSTER_ISAAC_SIM_CACHE_DIR=/some/path/on/cluster/docker-isaac-sim
# Cluster login
CLUSTER_LOGIN=username@cluster_ip
# Cluster scratch directory to store the SIF file
# e.g. /cluster/scratch/$USER
CLUSTER_SIF_PATH=/some/path/on/cluster/
# Permanent Workspace Directory.
# All ephemeral workspaces will also be prefixed and present in the following path
CLUSTER_WORKSPACE_DIR=/some/path/on/cluster/workspace
# Where permanent artifacts will live within the permanent workspace
CLUSTER_ARTIFACTS_DIRNAME=artifacts
# Remove the temporary code copy after the job is done
REMOVE_CODE_COPY_AFTER_JOB=false
# Python executable within whole_body_tracking directory to run with the submitted job
CLUSTER_PYTHON_EXECUTABLE=scripts/rsl_rl/train.py

###
# Directory References and Names (to copy latest code for the run)
# These are based on the setup instructions in the README
# https://github.com/HybridRobotics/whole_body_tracking
###
LOCAL_ISAACLAB_DIRNAME=IsaacLab
CLUSTER_ISAACLAB_DIRNAME=isaaclab

CLUSTER_WBT_DIRNAME=whole_body_tracking
